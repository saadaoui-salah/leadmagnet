{
  "name": "zillow-real-estate-intelligence-carousel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render ZillowIntelligenceCarousel out/zillow-intelligence-carousel.mp4",
    "still": "remotion still ZillowIntelligenceCarousel --frame=60 --output=out/preview.png",
    "export:images": "powershell -ExecutionPolicy Bypass -File scripts/export-images.ps1",
    "export:linkedin-pdf": "powershell -ExecutionPolicy Bypass -File scripts/export-linkedin-pdf.ps1",
    "export:instagram": "powershell -ExecutionPolicy Bypass -File scripts/export-instagram-images.ps1",
    "typecheck": "tsc --noEmit",
    "dashboard": "cd dashboard && npm run dev",
    "sync:slides": "xcopy /E /I /Y out\\linkedin dashboard\\public\\out\\linkedin & xcopy /E /I /Y out\\instagram dashboard\\public\\out\\instagram",
    "export:all": "npm run export:linkedin-pdf & npm run export:instagram & npm run sync:slides"
  },
  "dependencies": {
    "@remotion/cli": "4.0.482",
    "@remotion/google-fonts": "4.0.482",
    "framer-motion": "^12.23.0",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "remotion": "4.0.482",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49"
  }
}
